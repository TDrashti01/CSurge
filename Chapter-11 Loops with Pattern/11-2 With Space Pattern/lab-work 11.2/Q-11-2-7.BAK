#include <stdio.h>
#include <conio.h>

main ()
{
	int i, j, s;

	clrscr();
	printf("\n\n");
	for (i = 1; i <= 5; i++)
	{
		for (j = 1; j <= 5 - i + 1; j++)
		{
			printf("%d", j);
		}

		for (s = 1; s <= 2 *(i - 1) + 1; s++)
		{
			printf(" ");
		}

		for (j = 5 - i + 1; j >= 1; j--)
		{
			printf("%d", j);
		}
		printf("\n");
	}

	getch();
}