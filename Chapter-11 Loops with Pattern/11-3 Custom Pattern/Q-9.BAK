#include <stdio.h>
#include <conio.h>
main ()
{
	int i, j, s;

	clrscr();
	printf("\n\n");
	for (i = 5; i >= 1; i--)
	{
		for (j = i; j <= 5; j++)
		{
			printf("%d", j);
		}
		for (s = 1; s < i; s++)
		{
			printf("  ");
		}
		for (j = i; j <= 5; j++)
		{
			printf("%d", j);
		}
		printf("\n");
	}

	getch();

}